const firebaseConfig = {
    apiKey: "YOUR_API_KEY",
    authDomain: "YOUR_PROJECT.firebaseapp.com",
    databaseURL: "https://YOUR_PROJECT-default-rtdb.asia-southeast1.firebasedatabase.app",
    projectId: "YOUR_PROJECT",
    storageBucket: "YOUR_PROJECT.appspot.com",
    messagingSenderId: "YOUR_SENDER_ID",
    appId: "YOUR_APP_ID"
};

// 初始化
firebase.initializeApp(firebaseConfig);
const database = firebase.database();

// 學生ID生成
function getStudentId() {
    const player = JSON.parse(localStorage.getItem('mulanPlayer') || '{}');
    return player.id || null;
}

// 儲存玩家資料
function savePlayerData(data) {
    const id = getStudentId();
    if (!id) return Promise.reject('No student ID');
    
    return database.ref(`students/${id}`).set({
        ...data,
        lastUpdate: firebase.database.ServerValue.TIMESTAMP
    });
}

// 記錄答案
function recordAnswer(island, level, question, answer, isCorrect, score) {
    const id = getStudentId();
    if (!id) return;
    
    const record = {
        studentId: id,
        name: JSON.parse(localStorage.getItem('mulanPlayer') || '{}').name,
        class: JSON.parse(localStorage.getItem('mulanPlayer') || '{}').class,
        island: island,
        level: level,
        question: question.substring(0, 100),
        answer: answer,
        isCorrect: isCorrect,
        score: score,
        timestamp: firebase.database.ServerValue.TIMESTAMP
    };
    
    const key = database.ref().child('answers').push().key;
    return database.ref(`answers/${key}`).set(record);
}

// 獲取所有學生資料（排行榜用）
function getAllStudents(callback) {
    database.ref('students').on('value', (snapshot) => {
        callback(snapshot.val() || {});
    });
}

// 獲取所有答案（老師監控用）
function getAllAnswers(callback) {
    database.ref('answers').on('value', (snapshot) => {
        callback(snapshot.val() || {});
    });
}

// 檢查島嶼解鎖狀態
function checkIslandUnlock(islandIndex) {
    const player = JSON.parse(localStorage.getItem('mulanPlayer') || '{}');
    const stamps = player.stamps || [false, false, false, false, false];
    
    if (islandIndex === 0) return true; // 第一島永遠解鎖
    return stamps[islandIndex - 1] === true; // 前一島完成才解鎖
}
